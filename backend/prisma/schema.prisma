// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  username      String        @unique
  fullname      String
  email         String        @unique
  password_hash String
  phone         String
  is_verified   Boolean
  status        String
  created_at    DateTime      @default(now()) @db.Timestamp
  updated_at    DateTime      @updatedAt @db.Timestamp
  deleted_at    DateTime?
  userProfiles  UserProfile[]
  sessions      Session[]

  @@map("users")
}

model UserProfile {
  id         String   @id @db.Uuid
  dob        DateTime @db.Timestamp
  gender     String
  address    String
  created_at DateTime @default(now()) @db.Timestamp
  updated_at DateTime @updatedAt @db.Timestamp

  user User @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_user_profile")

  @@map("user_profiles")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  session_id String   @unique
  user_id    String   @unique @db.Uuid
  ip_address String   @unique
  last_seen  DateTime @db.Timestamp
  expires_at DateTime @db.Timestamp
  created_at DateTime @default(now()) @db.Timestamp

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "fk_user_session")

  @@map("sessions")
}
